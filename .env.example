# Copia este archivo, renómbralo a '.env' y sustituye 
# los valores de ejemplo por tus credenciales reales.


# Credenciales del usuario estándar de la aplicación
MARIADB_USER=tu_usuario_aqui
MARIADB_PASSWORD=tu_contraseña_segura_aqui

# Nombre de la base de datos que creará el contenedor
MARIADB_DATABASE=gamenode

# Contraseña del administrador (root) de la base de datos
MARIADB_ROOT_PASSWORD=tu_contraseña_root_aqui