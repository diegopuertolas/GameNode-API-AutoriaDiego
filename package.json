{
  "name": "gamenode-api",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "start": "node src/app.js --config config.local.yaml",
    "dev": "nodemon -e js,yaml src/app.js -- --config config.local.yaml",
    "test:unit": "jest src/test/unit",
    "test:integration": "cross-env NODE_ENV=test jest src/test/integration --runInBand",
    "test": "npm run test:unit && npm run test:integration",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "js-yaml": "^4.1.1",
    "knex": "^3.1.0",
    "mysql2": "^3.18.2",
    "swagger-ui-express": "^5.0.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
